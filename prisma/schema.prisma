generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         String   @default("BRANCH_MANAGER")
  branchName   String?
  createdAt    DateTime @default(now())
  name         String?
  status       String   @default("ACTIVE")
}

model ManpowerSchedule {
  id                 String   @id
  branch             String
  startDate          String
  endDate            String
  selections         Json
  notes              Json
  originalSelections Json
  originalNotes      Json
  status             String   @default("Finalized")
  submittedAt        DateTime @default(now())
  originalAuthor     String
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  nickname  String?
  branch    String
  position  String?
  createdAt DateTime @default(now())

  @@unique([name, branch])
}

model BranchStaff {
  id                 Int       @id @default(autoincrement())
  name               String?
  branch             String?
  createdAt          DateTime  @default(now())
  role               String?
  nickname           String?
  nric               String?
  dob                String?
  age                String?
  gender             String?
  nationality        String?
  home_address       String?
  phone              String?
  email              String?
  residential        String?
  emergency_name     String?
  emergency_phone    String?
  emergency_relation String?
  signed_date        String?
  start_date         String?
  employment_type    String?
  status             String?
  bank               String?
  bank_name          String?
  bank_account       String?
  university         String?
  department         String?
  position           String?
  location           String?
  accessStatus       String?   @default("AUTHORIZED")
  biometricTemplate  String?
  contract           String?
  employeeId         String?
  endDate            String?
  probation          String?
  rate               String?
  updatedAt          DateTime? @updatedAt

  @@map("BranchStaff")
}

model AttendanceLog {
  id                Int      @id @default(autoincrement())
  date              String
  empNo             String
  empName           String
  clockInTime       String
  clockInSerialNo   String
  clockInEmailSent  Boolean  @default(false)
  clockOutTime      String?
  clockOutSerialNo  String?
  clockOutEmailSent Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([date, empNo])
}

model LeaveTransaction {
  id                 Int       @id @default(autoincrement())
  EmployeeCode       String?   @db.VarChar(50)
  LeaveTypeCode      String?   @db.VarChar(20)
  LeaveTransId       String?   @db.VarChar(200)
  ApplyDate          DateTime? @db.Timestamp(6)
  ApplyReason        String?   @db.VarChar(500)
  ApplyStatus        String?   @db.VarChar(10)
  Attachment         String?   @db.VarChar(500)
  DayNo              Decimal?  @db.Decimal(5, 1)
  HourNo             Decimal?  @db.Decimal(5, 1)
  Days               String?   @db.VarChar(10)
  Source             String?   @db.VarChar(20)
  LeaveAdjustmentId  String?   @db.VarChar(200)
  LeaveDate          DateTime? @db.Date
  FromTime           DateTime? @db.Time(6)
  ToTime             DateTime? @db.Time(6)
  IsHourly           Boolean?
  IsAdjustment       Boolean?
  LeaveCreditId      String?   @db.VarChar(200)
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  ActionRemark       String?   @db.VarChar(500)
  RequiredThirdParty Boolean?
  WorkingHours       Int?

  @@unique([LeaveTransId, LeaveDate], map: "unique_leave_trans")
}
