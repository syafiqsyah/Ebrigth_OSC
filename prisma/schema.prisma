generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String?
  email        String   @unique
  passwordHash String
  role         String   @default("BRANCH_MANAGER")
  branchName   String?
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
}

model ManpowerSchedule {
  id                 String   @id
  branch             String
  startDate          String
  endDate            String
  selections         Json
  notes              Json
  originalSelections Json
  originalNotes      Json
  status             String   @default("Finalized")
  submittedAt        DateTime @default(now())
  originalAuthor     String
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  nickname  String?
  branch    String
  position  String?
  createdAt DateTime @default(now())

  @@unique([name, branch])
}

model BranchStaff {
  id                 Int       @id @default(autoincrement())
  name               String?
  branch             String?
  createdAt          DateTime  @default(now())
  role               String?
  nickname           String?
  nric               String?
  dob                String?
  age                String?
  gender             String?
  nationality        String?
  home_address       String?
  phone              String?
  email              String?
  residential        String?
  emergency_name     String?
  emergency_phone    String?
  emergency_relation String?
  signed_date        String?
  start_date         String?
  employment_type    String?
  status             String?
  bank               String?
  bank_name          String?
  bank_account       String?
  university         String?
  department         String?
  position           String?
  location           String?
  accessStatus       String?   @default("AUTHORIZED")
  biometricTemplate  String?
  contract           String?
  employeeId         String?
  endDate            String?
  probation          String?
  rate               String?
  updatedAt          DateTime? @updatedAt

  @@map("BranchStaff")
}
